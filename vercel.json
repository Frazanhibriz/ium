{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/style\\.css",
      "dest": "/style.css"
    },
    {
      "src": "/hasil(/?.*)",
      "dest": "/api/hasil.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
